PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/landingpagesaas

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="LandingPageSaaS <noreply@landingpagesaas.com>"

# OpenAI — AI copy + landing page generation. Falls back to deterministic
# offline content if unset.
OPENAI_API_KEY=sk-...

# Pexels — real stock images for landing pages. Falls back to a keyless
# LoremFlickr source if unset.
PEXELS_API_KEY=

# Seeded admin account — created automatically on first successful DB
# connection if it doesn't already exist (see backend/config/db.js).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_password

# Frontend
CLIENT_URL=http://localhost:3000
